---
import { Image } from 'astro:assets';
import ThemeToggle from './ThemeToggle.astro';
import logoLightShort from '../assets/images/sigmedia_logo_white_bg_short.svg';
import logoDarkShort from '../assets/images/sigmedia_logo_dark_bg_short.svg';
import logoLightFull from '../assets/images/sigmedia_logo_white_bg.svg';
import logoDarkFull from '../assets/images/sigmedia_logo_dark_bg.svg';

const navItems = [
  { href: `${import.meta.env.BASE_URL}team`, label: 'Team' },
  { href: `${import.meta.env.BASE_URL}publications`, label: 'Publications' },
  { href: `${import.meta.env.BASE_URL}datasets`, label: 'Datasets' },
  { href: `${import.meta.env.BASE_URL}software`, label: 'Software' },
  { href: `${import.meta.env.BASE_URL}jobs`, label: 'Jobs' },
  { href: `${import.meta.env.BASE_URL}blog`, label: 'Blog' },
];

const isLandingPage = Astro.url.pathname === import.meta.env.BASE_URL || Astro.url.pathname === `${import.meta.env.BASE_URL}/`;
---
<header class="bg-white dark:bg-dark-bg border-b border-gray-200 dark:border-gray-800 transition-colors duration-300">
  <div class="container mx-auto px-6">
    <nav class="flex items-center justify-between h-20 md:gap-8">
      <div class="flex items-center">
        {!isLandingPage && (
          <a href={import.meta.env.BASE_URL} class="flex items-center hover:opacity-80 transition-opacity">
            {/* Short logo for Mobile & Tablet */}
            <div class="lg:hidden flex items-center">
              <Image src={logoLightShort} alt="Sigmedia Logo" class="h-16 md:h-20 w-auto dark:hidden" loading="eager" />
              <Image src={logoDarkShort} alt="Sigmedia Logo" class="h-16 md:h-20 w-auto hidden dark:block" loading="eager" />
            </div>
            {/* Full logo for Desktop */}
            <div class="hidden lg:flex items-center">
              <Image src={logoLightFull} alt="Sigmedia Logo" class="h-16 w-auto dark:hidden" loading="eager" />
              <Image src={logoDarkFull} alt="Sigmedia Logo" class="h-16 w-auto hidden dark:block" loading="eager" />
            </div>
          </a>
        )}
      </div>
      
      {/* Desktop Menu */}
      <div class="hidden md:flex items-center space-x-8">
        <ul class="flex space-x-8">
          {navItems.map(item => (
            <li>
              <a href={item.href} class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-brand-dark dark:hover:text-brand transition-colors uppercase tracking-wider">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <ThemeToggle />
      </div>

      {/* Mobile Menu Button */}
      <div class="flex items-center space-x-4 md:hidden">
        <ThemeToggle />
        <button id="mobile-menu-button" class="p-2 text-gray-600 dark:text-gray-400 hover:text-brand-dark dark:hover:text-brand transition-colors focus:outline-none" aria-label="Toggle Menu">
          <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
          </svg>
          <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  {/* Mobile Menu Overlay */}
  <div id="mobile-menu" class="hidden md:hidden bg-white dark:bg-dark-bg border-t border-gray-100 dark:border-gray-800 transition-all duration-300 overflow-hidden">
    <div class="container mx-auto px-6 py-6">
      <ul class="flex flex-col space-y-4">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="block text-lg font-semibold text-gray-900 dark:text-white hover:text-brand-dark dark:hover:text-brand transition-colors uppercase tracking-widest">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<script>
  const setupMobileMenu = () => {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (button && menu && menuIcon && closeIcon) {
      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        
        // Toggle menu visibility
        menu.classList.toggle('hidden');
        
        // Toggle icons
        menuIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
        
        // Update accessibility
        button.setAttribute('aria-expanded', String(!isExpanded));
      });
    }
  };

  // Run on page load
  setupMobileMenu();
  
  // Run on view transitions
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
