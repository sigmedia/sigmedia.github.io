---
import yaml from 'js-yaml';
import fs from 'node:fs';
import path from 'node:path';

const dataPath = path.resolve('./src/data/collaborations.yml');
const collaborations = yaml.load(fs.readFileSync(dataPath, 'utf8')) as any;
---

<div class="my-16">
  <h2 class="text-3xl font-bold text-gray-900 mb-8">Research Bodies</h2>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-16">
    {collaborations.research_bodies.map((body: any) => (
      <a href={body.url} class="group flex flex-col items-center justify-center p-6 bg-white border border-gray-100 rounded-xl shadow-sm hover:shadow-md hover:border-blue-100 transition-all">
        <img src={body.logo} alt={body.name} class="h-16 w-auto object-contain grayscale group-hover:grayscale-0 transition-all duration-300" />
        <span class="mt-4 text-sm font-medium text-gray-500 group-hover:text-blue-600 transition-colors text-center">{body.name}</span>
      </a>
    ))}
  </div>

  <h2 class="text-3xl font-bold text-gray-900 mb-8">Industrial Collaborations</h2>
  <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 gap-6">
    {collaborations.industrial_collaborations.map((corp: any) => (
      <a href={corp.url} class="group flex flex-col items-center justify-center p-4 bg-white border border-gray-100 rounded-lg hover:shadow-sm hover:border-blue-50 transition-all">
        <img src={corp.logo} alt={corp.name} class="h-10 w-auto object-contain opacity-60 group-hover:opacity-100 transition-opacity" />
        <span class="mt-2 text-[10px] uppercase tracking-wider font-semibold text-gray-400 group-hover:text-gray-700 transition-colors">{corp.name}</span>
      </a>
    ))}
  </div>
</div>
