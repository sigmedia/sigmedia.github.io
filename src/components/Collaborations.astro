---
import yaml from 'js-yaml';
import fs from 'node:fs';
import path from 'node:path';
import { Image } from 'astro:assets';

const dataPath = path.resolve('./src/data/collaborations.yml');
const collaborations = yaml.load(fs.readFileSync(dataPath, 'utf8')) as any;

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/collaborations/*.{jpeg,jpg,png,gif}');
---

<div class="my-16">
  <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Research Bodies</h2>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-16">
    {collaborations.research_bodies.map((body: any) => {
      const imagePath = body.logo.replace('../assets/images/collaborations/', '');
      const imageKey = `../assets/images/collaborations/${imagePath}`;
      const whiteImageKey = imageKey.replace('.png', '_white.png');
      
      return (
        <a href={body.url} class="group flex flex-col items-center justify-center p-6 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-xl shadow-sm hover:shadow-md hover:border-blue-100 dark:hover:border-blue-900 transition-all">
          <div class="relative h-16 w-full flex items-center justify-center">
            {images[imageKey] && (
              <Image 
                src={images[imageKey]()} 
                alt={body.name} 
                class="h-16 w-auto object-contain grayscale group-hover:grayscale-0 transition-all duration-300 dark:hidden" 
              />
            )}
            {images[whiteImageKey] ? (
              <Image 
                src={images[whiteImageKey]()} 
                alt={body.name} 
                class="h-16 w-auto object-contain hidden dark:block grayscale group-hover:grayscale-0 transition-all duration-300" 
              />
            ) : images[imageKey] && (
               <Image 
                src={images[imageKey]()} 
                alt={body.name} 
                class="h-16 w-auto object-contain hidden dark:block grayscale group-hover:grayscale-0 transition-all duration-300 dark:invert dark:brightness-200" 
              />
            )}
          </div>
          <span class="mt-4 text-sm font-medium text-gray-500 dark:text-gray-400 group-hover:text-blue-600 transition-colors text-center">{body.name}</span>
        </a>
      );
    })}
  </div>

  <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Industrial Collaborations</h2>
  <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 gap-6">
    {collaborations.industrial_collaborations.map((corp: any) => {
      const imagePath = corp.logo.replace('../assets/images/collaborations/', '');
      const imageKey = `../assets/images/collaborations/${imagePath}`;
      const whiteImageKey = imageKey.replace('.png', '_white.png');
      
      return (
        <a href={corp.url} class="group flex flex-col items-center justify-center p-4 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-lg hover:shadow-sm hover:border-blue-50 dark:hover:border-blue-950 transition-all">
          <div class="relative h-10 w-full flex items-center justify-center">
            {images[imageKey] && (
              <Image 
                src={images[imageKey]()} 
                alt={corp.name} 
                class="h-10 w-auto object-contain opacity-60 group-hover:opacity-100 transition-opacity dark:hidden" 
              />
            )}
            {images[whiteImageKey] ? (
              <Image 
                src={images[whiteImageKey]()} 
                alt={corp.name} 
                class="h-10 w-auto object-contain hidden dark:block opacity-60 group-hover:opacity-100 transition-opacity" 
              />
            ) : images[imageKey] && (
               <Image 
                src={images[imageKey]()} 
                alt={corp.name} 
                class="h-10 w-auto object-contain hidden dark:block opacity-60 group-hover:opacity-100 transition-opacity dark:invert dark:brightness-200" 
              />
            )}
          </div>
          <span class="mt-2 text-[10px] uppercase tracking-wider font-semibold text-gray-400 dark:text-gray-500 group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors">{corp.name}</span>
        </a>
      );
    })}
  </div>
</div>
