---
import { Image } from 'astro:assets';
import tcdLogo from '../assets/images/tcd_logo.png';
import tcdLogoWhite from '../assets/images/tcd_logo_white.png';
const year = new Date().getFullYear();
---
<footer class="bg-gray-50 dark:bg-dark-bg border-t-4 border-brand pt-16 pb-8 transition-colors duration-300">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-6">Sigmedia</h3>
        <a href="https://www.tcd.ie/" class="block max-w-[200px]">
          <Image src={tcdLogo} alt="Trinity College Dublin" class="h-auto w-full opacity-80 hover:opacity-100 transition-opacity dark:hidden" />
          <Image src={tcdLogoWhite} alt="Trinity College Dublin" class="h-auto w-full opacity-80 hover:opacity-100 transition-opacity hidden dark:block" />
        </a>
      </div>
      
      <div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-6">Links</h3>
        <ul class="space-y-3">
          <li>
            <a href="https://github.com/sigmedia" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
              Github
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-6">Contact</h3>
        <address class="text-gray-600 dark:text-gray-400 not-italic leading-relaxed">
          Electronic & Electrical Engineering,<br />
          Aras an Phiarsaigh,<br />
          Trinity College Dublin,<br />
          Dublin 2, Ireland
        </address>
      </div>
    </div>
    
    <div class="border-t border-gray-200 dark:border-gray-800 pt-8 text-center text-sm text-gray-500 dark:text-gray-400">
      <p>© {year} Sigmedia - Signal Processing and Media Applications</p>
    </div>
  </div>
</footer>
