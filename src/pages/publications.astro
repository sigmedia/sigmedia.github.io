---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import bibtexParse from 'bibtex-parse-js';
import katex from 'katex';

const bibDir = path.resolve('./src/data/publis/');
const bibFiles = fs.readdirSync(bibDir).filter(f => f.endsWith('.bib'));

let allEntries: any[] = [];

bibFiles.forEach(file => {
  let content = fs.readFileSync(path.join(bibDir, file), 'utf8');
  
  // Pre-process content to handle capitalized unquoted month macros (e.g., month = Sept)
  // which cause bibtex-parse-js to fail.
  content = content.replace(/month\s*=\s*([A-Za-z]+)\b/g, (match, p1) => {
    const lower = p1.toLowerCase();
    const monthMap: Record<string, string> = {
      january: 'jan', febuary: 'feb', february: 'feb', march: 'mar', april: 'apr',
      may: 'may', june: 'jun', july: 'jul', august: 'aug', september: 'sep', sept: 'sep',
      october: 'oct', november: 'nov', december: 'dec'
    };
    // Also handle 3-letter abbreviations
    const months3 = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'];
    
    if (monthMap[lower]) {
      return `month = ${monthMap[lower]}`;
    } else if (months3.includes(lower)) {
      return `month = ${lower}`;
    }
    return match;
  });

  try {
    const entries = bibtexParse.toJSON(content);
    allEntries = allEntries.concat(entries);
  } catch (e) {
    console.error(`Error parsing ${file}:`, e);
  }
});

// Group by year
const groupedByYear = allEntries.reduce((acc, entry) => {
  const year = entry.entryTags.year || 'Unknown';
  if (!acc[year]) acc[year] = [];
  acc[year].push(entry);
  return acc;
}, {} as Record<string, any[]>);

const years = Object.keys(groupedByYear)
  .filter(year => year !== 'Unknown')
  .sort((a, b) => b.localeCompare(a));

function latexToUnicode(str: string) {
  if (!str) return '';
  return str
    .replace(/\\'(?:{\\i}|\\i|([aeiouyAEIOUY]))/g, (m, p1) => (p1 || 'i') + '\u0301')
    .replace(/\\`(?:{\\i}|\\i|([aeiouyAEIOUY]))/g, (m, p1) => (p1 || 'i') + '\u0300')
    .replace(/\\\^(?:{\\i}|\\i|([aeiouyAEIOUY]))/g, (m, p1) => (p1 || 'i') + '\u0302')
    .replace(/\\"(?:{\\i}|\\i|([aeiouyAEIOUY]))/g, (m, p1) => (p1 || 'i') + '\u0308')
    .replace(/\\~(?:{\\i}|\\i|([anouANOU]))/g, (m, p1) => (p1 || 'i') + '\u0303')
    .replace(/\\v\s*{?(\\i|\\j|([a-zA-Z]))}?/g, (m, p1, p2) => {
      const char = p2 || (p1 === '\\i' ? 'i' : 'j');
      return char + '\u030c';
    })
    .replace(/\\i\b/g, 'i')
    .replace(/\\j\b/g, 'j')
    .replace(/\\c\s*{?c}?/g, 'ç')
    .replace(/\\c\s*{?C}?/g, 'Ç')
    .replace(/\\less\b/g, '<')
    .replace(/\\greater\b/g, '>')
    .replace(/\\&/g, '&')
    .replace(/\\_/g, '_')
    .replace(/\\%/g, '%')
    .replace(/\\#/g, '#')
    .normalize('NFC');
}

function cleanValue(str: string) {
  if (!str) return '';
  let cleaned = str.replace(/{/g, '').replace(/}/g, '').trim();
  // Handle math-escaped symbols
  cleaned = cleaned.replace(/\$&\$/g, '&');
  // Remove pseudo-HTML tags and their LaTeX-wrapped versions
  cleaned = cleaned.replace(/(\$?\\less\$?)\s*\/?(inf|sub|sup|b|i|u)\s*(\$?\\greater\$?)/gi, '');
  cleaned = cleaned.replace(/<\/?(inf|sub|sup|b|i|u)>/gi, '');
  return latexToUnicode(cleaned);
}

function renderMath(str: string) {
  if (!str) return '';
  // 1. Remove outer curly braces used for BibTeX escaping
  let text = str.replace(/{/g, '').replace(/}/g, '').trim();

  // Handle math-escaped symbols before splitting
  text = text.replace(/\$&\$/g, '&');

  // 2. Convert specific LaTeX pseudo-math tags to real HTML tags
  text = text.replace(/(\$?\\less\$?)\s*inf\s*(\$?\\greater\$?)/gi, '<sub>');
  text = text.replace(/(\$?\\less\$?)\s*\/inf\s*(\$?\\greater\$?)/gi, '</sub>');
  text = text.replace(/(\$?\\less\$?)\s*sub\s*(\$?\\greater\$?)/gi, '<sub>');
  text = text.replace(/(\$?\\less\$?)\s*\/sub\s*(\$?\\greater\$?)/gi, '</sub>');
  text = text.replace(/(\$?\\less\$?)\s*sup\s*(\$?\\greater\$?)/gi, '<sup>');
  text = text.replace(/(\$?\\less\$?)\s*\/sup\s*(\$?\\greater\$?)/gi, '</sup>');
  
  // 3. Identify and render remaining Math segments
  const segments = text.split(/(\$[^$]+\$)/g);
  return segments.map(seg => {
    if (seg.startsWith('$') && seg.endsWith('$')) {
      const math = seg.slice(1, -1)
        .replace(/\\less\b/g, '<')
        .replace(/\\greater\b/g, '>');
      try {
        return katex.renderToString(math, { 
          throwOnError: false, 
          displayMode: false,
          output: 'html' 
        });
      } catch (e) {
        return seg;
      }
    } else {
      // 4. Apply LaTeX accent conversion ONLY to non-math segments
      return latexToUnicode(seg);
    }
  }).join('');
}

function normalizeSearch(str: string) {
  if (!str) return '';
  return str
    .normalize('NFD') // Decompose combined characters (e.g., 'ç' to 'c' + '◌̧')
    .replace(/[\u0300-\u036f]/g, '') // Remove the diacritic marks
    .toLowerCase();
}

function formatAuthors(authorStr: string) {
  if (!authorStr) return '';
  const cleanedStr = cleanValue(authorStr);
  const authors = cleanedStr.split(' and ').map(a => {
    const parts = a.split(',');
    if (parts.length === 2) return `${parts[1].trim()} ${parts[0].trim()}`;
    return a.trim();
  });
  if (authors.length <= 5) return authors.join(', ');
  return authors.slice(0, 5).join(', ') + ' et al.';
}
---

<BaseLayout title="Publications | Sigmedia">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-8 tracking-tight text-center">Publications</h1>

    {/* Search Bar */}
    <div class="mb-12 sticky top-24 z-20">
      <div class="relative max-w-2xl mx-auto">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
          </svg>
        </div>
        <input 
          type="text" 
          id="pub-search" 
          placeholder="Search by title, author, or venue..." 
          class="block w-full pl-11 pr-4 py-4 bg-white dark:bg-dark-bg border-2 border-gray-100 dark:border-gray-800 rounded-2xl shadow-lg focus:ring-4 focus:ring-brand/20 focus:border-brand transition-all outline-none text-lg dark:text-white dark:placeholder-gray-500"
        />
      </div>
    </div>

    <div class="space-y-10" id="publications-list">
      {years.map(year => (
        <section id={`year-${year}`} class="year-section">
          <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white mb-4 border-b-2 border-brand pb-1 inline-block">
            {year}
          </h2>
          <div class="space-y-3">
            {groupedByYear[year].map((entry: any) => (
              <div 
                class="pub-card bg-white dark:bg-dark-bg p-4 rounded-lg border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md transition-shadow"
                data-search={normalizeSearch(
                  (entry.entryTags.title || '') + ' ' + 
                  (entry.entryTags.author || '') + ' ' + 
                  (entry.entryTags.journal || entry.entryTags.booktitle || '')
                )}
              >
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2">
                  <div class="flex-grow">
                    <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1 leading-snug" set:html={renderMath(entry.entryTags.title)} />
                    <p class="text-sm text-gray-700 dark:text-gray-300 mb-0.5">
                      <span class="font-semibold">{formatAuthors(entry.entryTags.author)}</span>
                    </p>
                    <p class="text-xs text-gray-500 dark:text-gray-400 italic">
                      {cleanValue(entry.entryTags.journal || entry.entryTags.booktitle || entry.entryTags.publisher)}
                      {entry.entryTags.volume && `, vol. ${entry.entryTags.volume}`}
                      {entry.entryTags.number && `, no. ${entry.entryTags.number}`}
                      {entry.entryTags.pages && `, pp. ${entry.entryTags.pages}`}
                    </p>
                  </div>
                  
                  <div class="flex flex-wrap gap-1.5 mt-2 md:mt-0">
                    <button 
                      class="bib-toggle px-2 py-0.5 bg-gray-50 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-md text-[10px] font-bold hover:bg-brand hover:text-gray-900 transition-colors uppercase tracking-wider"
                      data-target={`bib-${entry.citationKey}`}
                    >
                      BIB
                    </button>
                    {entry.entryTags.doi && (
                      <a href={`https://doi.org/${entry.entryTags.doi}`} target="_blank" class="px-2 py-0.5 bg-gray-50 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-md text-[10px] font-bold hover:bg-brand hover:text-gray-900 transition-colors uppercase tracking-wider">
                        DOI
                      </a>
                    )}
                    {entry.entryTags.url && (
                      <a href={entry.entryTags.url} target="_blank" class="px-2 py-0.5 bg-gray-50 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-md text-[10px] font-bold hover:bg-brand hover:text-gray-900 transition-colors uppercase tracking-wider">
                        URL
                      </a>
                    )}
                  </div>
                </div>
                
                {/* BibTeX Expandable */}
                <div id={`bib-${entry.citationKey}`} class="hidden mt-3 pt-3 border-t border-gray-100 dark:border-gray-800">
                  <div class="relative group/bib">
                    <pre class="bg-[var(--shiki-light-bg)] dark:bg-[var(--shiki-dark-bg)] text-gray-900 dark:text-gray-100 p-4 rounded-lg text-[10px] overflow-x-auto font-mono leading-relaxed border border-gray-100 dark:border-gray-800 shadow-inner whitespace-pre-wrap">{`@${entry.entryType}{${entry.citationKey},
${Object.entries(entry.entryTags).map(([k, v]) => `  ${k} = {${v}}`).join(',\n')}
}`}</pre>
                    <button 
                      class="copy-bib absolute top-4 right-4 p-2 bg-white dark:bg-dark-bg border border-gray-200 dark:border-gray-800 shadow-sm hover:border-brand hover:text-brand-dark dark:hover:text-brand rounded-xl text-gray-400 dark:text-gray-500 transition-all opacity-0 group-hover/bib:opacity-100"
                      data-bib={`@${entry.entryType}{${entry.citationKey},\n${Object.entries(entry.entryTags).map(([k, v]) => `  ${k} = {${v}}`).join(',\n')}\n}`}
                      title="Copy BibTeX"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    {/* Empty State */}
    <div id="no-results" class="hidden py-20 text-center">
      <p class="text-xl text-gray-400">No publications found matching your search.</p>
      <button 
        onclick="document.getElementById('pub-search').value = ''; document.getElementById('pub-search').dispatchEvent(new Event('input'));"
        class="mt-4 text-brand-dark font-bold hover:underline"
      >
        Clear search
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('pub-search') as HTMLInputElement;
  const pubCards = document.querySelectorAll('.pub-card');
  const yearSections = document.querySelectorAll('.year-section');
  const noResults = document.getElementById('no-results');

  function normalizeSearch(str: string) {
    return str
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase();
  }

  searchInput?.addEventListener('input', (e) => {
    const query = normalizeSearch((e.target as HTMLInputElement).value);
    let totalVisible = 0;

    yearSections.forEach(section => {
      const cards = section.querySelectorAll('.pub-card');
      let visibleInYear = 0;

      cards.forEach(card => {
        const searchText = (card as HTMLElement).dataset.search || '';
        if (searchText.includes(query)) {
          (card as HTMLElement).style.display = 'block';
          visibleInYear++;
          totalVisible++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      // Hide year section if no cards match
      (section as HTMLElement).style.display = visibleInYear > 0 ? 'block' : 'none';
    });

    // Show/hide empty state
    if (noResults) {
      noResults.style.display = totalVisible === 0 ? 'block' : 'none';
    }
  });
  // Toggle BibTeX
  document.querySelectorAll('.bib-toggle').forEach(button => {
    button.addEventListener('click', () => {
      const targetId = (button as HTMLElement).dataset.target;
      if (targetId) {
        const target = document.getElementById(targetId);
        if (target) {
          target.classList.toggle('hidden');
          button.classList.toggle('bg-brand');
        }
      }
    });
  });

  // Copy BibTeX
  document.querySelectorAll('.copy-bib').forEach(button => {
    button.addEventListener('click', () => {
      const bib = (button as HTMLElement).dataset.bib || '';
      navigator.clipboard.writeText(bib).then(() => {
        const originalInner = button.innerHTML;
        button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
        setTimeout(() => {
          button.innerHTML = originalInner;
        }, 2000);
      });
    });
  });
</script>
