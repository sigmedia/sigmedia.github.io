---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Jobs | Sigmedia">
  <div class="max-w-3xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-8 tracking-tight">Job Openings</h1>
    
    <div class="prose prose-blue max-w-none">
      <p class="text-lg text-gray-600 mb-8">
        Current positions are always listed on the main <a href="http://www.tcd.ie/vacancies" class="text-blue-600 hover:underline">TCD vacancies webpage</a>.
      </p>

      <section class="bg-blue-50 p-8 rounded-2xl border border-blue-100 mb-12">
        <h2 class="text-2xl font-bold text-blue-900 mb-4 mt-0">Prospective PhD Candidates</h2>
        <p>
          Prospective PhD candidates should contact us during their final year of study to
          explore funding opportunities. We consider applications from candidates with a
          first-class degree (expected) in a numerate discipline e.g. Electronics,
          Computer Science or Mathematics.
        </p>
        <p class="font-medium text-blue-800">
          Experience in signal processing and Matlab or Python is a distinct advantage.
        </p>
        <p>
          Please send a short CV and motivation letter, including the names of at least 2 referees, to prospective Advisors listed on the <a href="/team" class="font-bold underline">Team page</a>.
        </p>
      </section>

      <div class="space-y-8">
        <div>
          <h3 class="text-xl font-bold text-gray-900">Postdoctoral Positions</h3>
          <p>
            Postdoctoral posts will be advertised on the main TCD web pages. It is always worth contacting us a few months in advance of your potential availability if you believe your research is a particularly good match for the Lab.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-bold text-gray-900">Internships</h3>
          <p>
            We frequently take on talented interns. See our <a href="/" class="text-blue-600 hover:underline">Research page</a> to get an overview of the research in the group.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
