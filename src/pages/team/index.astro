---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTeamSlug } from '../../utils/routes';

const members = await getCollection('team');
const landingSocialPlatforms = ['linkedin', 'website', 'google-scholar'];
const socialIcons: Record<string, string> = {
  twitter: 'sig-icon sig-icon-brand sig-icon-twitter',
  linkedin: 'sig-icon sig-icon-brand sig-icon-linkedin',
  github: 'sig-icon sig-icon-brand sig-icon-github',
  website: 'sig-icon sig-icon-solid sig-icon-website',
  email: 'sig-icon sig-icon-solid sig-icon-email',
  'google-scholar': 'sig-icon sig-icon-solid sig-icon-google-scholar',
  orcid: 'sig-icon sig-icon-brand sig-icon-orcid',
  'research-gate': 'sig-icon sig-icon-brand sig-icon-research-gate',
  wikipedia: 'sig-icon sig-icon-brand sig-icon-wikipedia'
};

const categories = [
  { id: 'staff', label: 'Academic Staff' },
  { id: 'Postdoc', label: 'Postdoctoral Researchers' },
  { id: 'Research-Assistant', label: 'Research Assistants' },
  { id: 'PhD-Student', label: 'PhD Students' },
  { id: 'others', label: 'Other Members' },
  { id: 'alumni', label: 'Alumni' }
];

const groupedMembers = categories.reduce((acc, cat) => {
  acc[cat.id] = members
    .filter(m => m.data.category === cat.id)
    .sort((a, b) => {
      const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
      const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
      return dateA - dateB;
    });
  return acc;
}, {} as Record<string, any[]>);
---

<BaseLayout title="Team | Sigmedia">
  <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-12 tracking-tight">Our Team</h1>

  <div class="space-y-20">
    {categories.map(cat => groupedMembers[cat.id].length > 0 && (
      <section id={cat.id}>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 border-b-4 border-brand pb-2 inline-block">{cat.label}</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6 gap-6">
          {groupedMembers[cat.id].map(member => (
            (() => {
              const profileHref = `${import.meta.env.BASE_URL}team/${getTeamSlug(member.data, member.id)}`;
              const normalizedSocial = member.data.social ? {
                ...member.data.social,
                orcid: member.data.social.orcid || member.data.social.orchid,
              } : undefined;
              const socialEntries = normalizedSocial
                ? landingSocialPlatforms
                  .map((platform) => [platform, normalizedSocial[platform]] as const)
                  .filter(([, url]) => Boolean(url))
                : [];

              return (
                <div class="group">
                  <a href={profileHref} class="block">
                    <div class="aspect-square overflow-hidden rounded-xl mb-3 bg-gray-100 dark:bg-gray-800">
                      {member.data.image ? (
                        <Image 
                          src={member.data.image} 
                          alt={member.data.title}
                          width={256}
                          height={256}
                          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center text-gray-300 dark:text-gray-600">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                          </svg>
                        </div>
                      )}
                    </div>
                    <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{member.data.title}</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400">{member.data.role}</p>
                  </a>

                  {socialEntries.length > 0 && (
                    <div class="mt-2 flex items-center gap-2">
                      {socialEntries.map(([platform, url]) => (
                        <a
                          href={platform === 'email' ? `mailto:${url}` : url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center justify-center p-0.5 text-gray-400 transition-colors hover:text-blue-600 dark:text-gray-500 dark:hover:text-blue-400"
                          title={platform}
                          aria-label={`${member.data.title} ${platform}`}
                        >
                          <span class:list={[socialIcons[platform], 'sig-icon-tiny']} aria-hidden="true"></span>
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              );
            })()
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
