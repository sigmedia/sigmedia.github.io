---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const members = await getCollection('team');
const categories = [
  { id: 'staff', label: 'Academic Staff' },
  { id: 'Postdoc', label: 'Postdoctoral Researchers' },
  { id: 'Research-Assistant', label: 'Research Assistants' },
  { id: 'PhD-Student', label: 'PhD Students' },
  { id: 'others', label: 'Other Members' },
  { id: 'alumni', label: 'Alumni' }
];

const groupedMembers = categories.reduce((acc, cat) => {
  acc[cat.id] = members
    .filter(m => m.data.category === cat.id)
    .sort((a, b) => {
      const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
      const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
      return dateA - dateB;
    });
  return acc;
}, {} as Record<string, any[]>);
---

<BaseLayout title="Team | Sigmedia">
  <h1 class="text-4xl font-bold text-gray-900 mb-12 tracking-tight">Our Team</h1>

  <div class="space-y-20">
    {categories.map(cat => groupedMembers[cat.id].length > 0 && (
      <section id={cat.id}>
        <h2 class="text-2xl font-bold text-gray-900 mb-8 border-b-4 border-brand pb-2 inline-block">{cat.label}</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6 gap-6">
          {groupedMembers[cat.id].map(member => (
            <a href={`/team/${member.id}`} class="group">
              <div class="aspect-square overflow-hidden rounded-xl mb-3 bg-gray-100 border border-gray-100">
                {member.data.image ? (
                  <Image 
                    src={member.data.image} 
                    alt={member.data.title}
                    width={256}
                    height={256}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-gray-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                )}
              </div>
              <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{member.data.title}</h3>
              <p class="text-sm text-gray-500">{member.data.role}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
