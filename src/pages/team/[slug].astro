---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RedirectLayout from '../../layouts/RedirectLayout.astro';
import { getTeamAliases, getTeamSlug } from '../../utils/routes';

export async function getStaticPaths() {
  const members = await getCollection('team');
  return members.flatMap((entry) => {
    const canonicalSlug = getTeamSlug(entry.data, entry.id);
    const paths = [{
      params: { slug: canonicalSlug },
      props: { entry },
    }];

    for (const alias of getTeamAliases(entry.data, entry.id)) {
      paths.push({
        params: { slug: alias },
        props: { redirectTarget: `${import.meta.env.BASE_URL}team/${canonicalSlug}` },
      });
    }

    return paths;
  });
}

const { entry, redirectTarget } = Astro.props;
const isRedirect = Boolean(redirectTarget);
const { Content } = isRedirect ? { Content: null } : await render(entry);
const { title, role, image, social } = isRedirect ? { title: '', role: '', image: undefined, social: undefined } : entry.data;

const socialIcons: Record<string, string> = {
  twitter: 'sig-icon sig-icon-brand sig-icon-twitter',
  linkedin: 'sig-icon sig-icon-brand sig-icon-linkedin',
  github: 'sig-icon sig-icon-brand sig-icon-github',
  website: 'sig-icon sig-icon-solid sig-icon-website',
  email: 'sig-icon sig-icon-solid sig-icon-email',
  'google-scholar': 'sig-icon sig-icon-solid sig-icon-google-scholar',
  orcid: 'sig-icon sig-icon-brand sig-icon-orcid',
  'research-gate': 'sig-icon sig-icon-brand sig-icon-research-gate',
  wikipedia: 'sig-icon sig-icon-brand sig-icon-wikipedia'
};

const normalizedSocial = social ? {
  ...social,
  orcid: social.orcid || social.orchid,
} : undefined;

const socialEntries = normalizedSocial
  ? Object.entries(normalizedSocial).filter(([platform, url]) => Boolean(url) && Boolean(socialIcons[platform]))
  : [];
---

{isRedirect ? (
  <RedirectLayout target={redirectTarget} />
) : (
  <BaseLayout title={`${title} | Sigmedia`}>
    <div class="max-w-3xl mx-auto">
      <nav class="mb-8">
        <a href={`${import.meta.env.BASE_URL}team`} class="text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 flex items-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Team
        </a>
      </nav>

      <header class="text-center mb-12">
        <div class="inline-block relative">
          <div class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden mb-6 border-4 border-white dark:border-gray-800 shadow-xl mx-auto">
            {image ? (
              <Image src={image} alt={title} width={512} height={512} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-gray-300 dark:text-gray-600">
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            )}
          </div>
        </div>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">{title}</h1>
        <p class="text-xl text-gray-500 dark:text-gray-400 mb-6">{role}</p>

        {socialEntries.length > 0 && (
          <div class="flex justify-center space-x-4">
            {socialEntries.map(([platform, url]) => (
              <a href={platform === 'email' ? `mailto:${url}` : url} target="_blank" rel="noopener noreferrer" class="p-2 bg-gray-50 dark:bg-dark-bg rounded-full text-gray-400 dark:text-gray-500 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-all" title={platform}>
                <span class={socialIcons[platform]} aria-hidden="true"></span>
              </a>
            ))}
          </div>
        )}
      </header>

      <article class="prose prose-blue dark:prose-invert max-w-none prose-img:rounded-xl">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Biography</h3>
        <Content />
      </article>
    </div>
  </BaseLayout>
)}
