---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const datasets = await getCollection('dataset');
---

<BaseLayout title="Datasets | Sigmedia">
  <div class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-8 tracking-tight">Datasets</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-12">
      Sigmedia research group provides several datasets for the community.
    </p>

    <div class="divide-y divide-gray-100 dark:divide-gray-800">
      {datasets.map(dataset => (
        <a href={`${import.meta.env.BASE_URL}datasets/${dataset.id}`} class="group flex items-center justify-between py-4 hover:bg-gray-50/50 dark:hover:bg-gray-900/30 px-4 -mx-4 rounded-xl transition-all">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{dataset.data.title}</h2>
          <div class="flex items-center text-blue-600 dark:text-blue-400 opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0">
            <span class="text-sm font-medium mr-2">View details</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
