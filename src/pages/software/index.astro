---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const software = await getCollection('software');
---

<BaseLayout title="Software | Sigmedia">
  <div class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-8 tracking-tight">Software</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-12">
      Open source software and tools developed by the Sigmedia research group.
    </p>

    <div class="divide-y divide-gray-100 dark:divide-gray-800">
      {software.map(item => (
        <div class="py-6 flex flex-col md:flex-row md:items-center justify-between gap-4 group">
          <div class="flex-grow">
            <div class="flex items-center gap-3 mb-1">
              <h2 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                <a href={`${import.meta.env.BASE_URL}software/${item.id}`}>
                  {item.data.title}
                </a>
              </h2>
              {item.data.license && (
                <span class="px-2 py-0.5 text-xs font-medium border border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 rounded-full">
                  {item.data.license}
                </span>
              )}
            </div>
            
            <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
              {item.data.language && (
                <div class="flex items-center gap-1.5">
                  <span class={`w-3 h-3 rounded-full ${
                    item.data.language === 'Python' ? 'bg-blue-500' : 
                    item.data.language === 'C++' ? 'bg-pink-500' : 
                    item.data.language === 'Matlab' ? 'bg-orange-500' : 
                    item.data.language === 'JavaScript' ? 'bg-yellow-400' : 'bg-gray-400'
                  }`}></span>
                  {item.data.language}
                </div>
              )}
              
              {item.data.repository && (
                <a 
                  href={item.data.repository} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="flex items-center gap-1 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                  </svg>
                  Source
                </a>
              )}
            </div>
          </div>
          
          <div class="flex items-center gap-2">
            <a 
              href={`${import.meta.env.BASE_URL}software/${item.id}`}
              class="px-4 py-1.5 text-sm font-medium bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors shadow-sm"
            >
              Details
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
