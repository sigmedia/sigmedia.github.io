---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Sigmedia">
  <div class="max-w-2xl mx-auto py-20 text-center">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">Page Not Found</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
      Sorry, but the page you were trying to view does not exist.
    </p>
    <a
      href={import.meta.env.BASE_URL}
      class="inline-flex items-center rounded-lg bg-brand px-5 py-3 font-semibold text-gray-900 transition-opacity hover:opacity-90"
    >
      Return Home
    </a>
  </div>
</BaseLayout>
