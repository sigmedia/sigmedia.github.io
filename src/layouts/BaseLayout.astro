---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Sigmedia - Signal Processing and Media Applications", description = "Research group in Trinity College Dublin focused on signal processing for video and audio." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
  </head>
  <body class="min-h-screen bg-white font-sans text-gray-900 flex flex-col">
    <Header />
    <main class="flex-grow container mx-auto px-6 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --accent: 255, 210, 0;
    --accent-gradient: linear-gradient(45deg, rgb(var(--accent)), #facc15 30%, white 60%);
  }
  html {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>
