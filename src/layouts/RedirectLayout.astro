---
interface Props {
  target: string;
  title?: string;
}

const { target, title = 'Redirecting | Sigmedia' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
  </head>
  <body>
    <p><a href={target}>Continue to the new page</a></p>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </body>
</html>
